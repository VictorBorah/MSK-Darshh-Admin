# Enforce LF (Unix) line endings on all text files
* text=auto eol=lf

# Explicitly ensure bash-related deployment scripts and Next.js configs are LF
*.sh text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf

# Windows specific files can retain CRLF only if absolutely necessary (e.g. .bat files)
*.bat text eol=crlf
